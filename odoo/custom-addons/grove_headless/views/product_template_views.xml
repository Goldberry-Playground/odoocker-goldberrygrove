<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <!-- Extend the product template form to show Grove headless fields -->
    <record id="product_template_form_view_grove" model="ir.ui.view">
        <field name="name">product.template.form.grove_headless</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view" />
        <field name="arch" type="xml">
            <xpath expr="//page[@name='sales']" position="after">
                <page string="Grove Headless" name="grove_headless">
                    <group>
                        <group string="Storefront">
                            <field name="grove_featured" />
                        </group>
                        <group string="SEO">
                            <field name="grove_seo_description" />
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
