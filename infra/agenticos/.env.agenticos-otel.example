# GOL-54 P1 — AgenticOS OTel Collector env template.
# Copy to `.env.agenticos-otel` on the AgenticOS box and fill in. DO NOT COMMIT the
# filled file (see .gitignore). Prefer injecting these via Infisical/1Password at deploy
# time (ADR-003) rather than a plaintext file on the box.

# --- obs-droplet OpenObserve OTLP ingest ---------------------------------------------
# The SEPARATE observability droplet's OpenObserve OTLP-HTTP base. Must be reachable from
# the AgenticOS box over the public/edge network (it is a different host by design).
# Shape: <scheme>://<obs-host>/api/<org>   (org is "default" in this stack).
OPENOBSERVE_OTLP_BASE=https://obs.gatheringatthegrove.com/api/default

# OpenObserve ingest credentials. TODAY: the obs-droplet root basicauth (same creds the
# odoocker collector uses). FOLLOW-UP (least privilege, tracked in README.md): replace
# with a scoped ingest-only OpenObserve user so root creds never live on AgenticOS.
OPENOBSERVE_ROOT_EMAIL=
OPENOBSERVE_ROOT_PASSWORD=

# --- tagging -------------------------------------------------------------------------
# deployment.environment label on every AgenticOS metric. Keep "agenticos" so the box is
# its own environment in dashboards/alerts (distinct from qa/prod app envs).
COST_ENV=agenticos

# --- image pin (optional) ------------------------------------------------------------
# OTELCOL_TAG=0.115.0
