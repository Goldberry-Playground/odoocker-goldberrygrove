# @grove/discord-bridge — environment
#
# Secrets are provisioned by Josh into 1Password `Grove Infra` (tracked in
# GOL-263) and injected at run time. NEVER commit real values. Left column =
# env var this app reads; right column = 1Password item key it maps to.

# Buffer (read-only insights token — X6cz). Already provisioned (GOL-226).
#   1P: Grove Infra / buffer_api_token
BUFFER_API_TOKEN=
# Buffer organization id — defaults to Goldberry Grove if unset.
BUFFER_ORG_ID=5a3295c5a73330590e63e1bb

# Discord bot (provisioned via GOL-263).
#   1P: Grove Infra / discord_bot_token
DISCORD_BOT_TOKEN=
#   1P: Grove Infra / discord_app_id
DISCORD_APP_ID=
#   1P: Grove Infra / discord_public_key   (Ed25519 request verification)
DISCORD_PUBLIC_KEY=
#   1P: Grove Infra / discord_insights_channel_id  (the #weekly-insights channel)
DISCORD_WEEKLY_INSIGHTS_CHANNEL_ID=

# Optional. Deep link used by the "Open in Buffer" button.
BUFFER_ANALYTICS_URL=https://publish.buffer.com

# Optional. Port the interactions server listens on (default 8787).
PORT=8787
