# Copy to terraform.tfvars (git-ignored) and fill in. Secrets normally flow via
# `op run --env-file=.env.op --` from 1Password (GoldberryGrove Infra), same as
# the other envs — see README.md.

region        = "nyc3"
droplet_size  = "s-2vcpu-4gb"
admin_ip_cidr = "203.0.113.4/32" # your /32 — NEVER 0.0.0.0/0

# Cross-plane OTLP ingest sources (5080) — collectors on OTHER droplets, /32 each.
# Kept separate from admin_ip_cidr so ingest never widens admin/UI access. Empty
# = admin-only. Prod value: the agenticos droplet -> ["159.223.171.231/32"].
ingest_source_cidrs = []

# SSH
ci_ssh_public_key  = "ssh-ed25519 AAAA... grove-obs-deploy"
admin_ssh_key_name = "grove-qa-admin" # reused out-of-band admin key

# Secrets (prefer op:// injection over literals here)
do_token                  = "dop_v1_..."
openobserve_root_email    = "monitoring@grove.local"
openobserve_root_password = "CHANGE_ME"
keep_webhook_token        = "openssl-rand-hex-32"
keep_nextauth_secret      = "openssl-rand-hex-32"
discord_webhook_warning   = "https://discord.com/api/webhooks/.../warning"
discord_webhook_critical  = "https://discord.com/api/webhooks/.../critical"

# OpenObserve Parquet storage → DO Spaces
spaces_endpoint   = "https://nyc3.digitaloceanspaces.com"
spaces_bucket     = "grove-openobserve-data"
spaces_access_key = "DO00..."
spaces_secret_key = "..."

cost_env = "prod"

# ── Public RUM ingest vhost (GOL-311) ────────────────────────────────────────
# rum_public_host + cors_allowed_origin_regex + cloudflare_ingress_cidrs all
# have sane defaults in variables.tf; override only if the hostname/origins move.
# The Cloudflare Origin Certificate + key are REQUIRED (no default) — inject from
# 1Password, never paste literals here. Generate once in the Cloudflare dashboard
# (SSL/TLS -> Origin Server -> Create Certificate) or the API, scoped to
# rum.gatheringatthegrove.com (or *.gatheringatthegrove.com), 15-year validity.
# rum_public_host = "rum.gatheringatthegrove.com"
cf_origin_cert_pem = <<-EOT
  -----BEGIN CERTIFICATE-----
  ...op://Grove Prod/grove-obs-rum/origin_cert...
  -----END CERTIFICATE-----
EOT
cf_origin_key_pem = <<-EOT
  -----BEGIN PRIVATE KEY-----
  ...op://Grove Prod/grove-obs-rum/origin_key...
  -----END PRIVATE KEY-----
EOT
