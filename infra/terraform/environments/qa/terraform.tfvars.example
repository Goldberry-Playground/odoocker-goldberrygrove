# Operator template. Copy to terraform.tfvars (git-ignored) ONLY if you need
# to override one of the defaults declared in variables.tf. In normal use the
# defaults + env-injected TF_VAR_* (via op run) are enough.

# Override only if your IPv4 has changed:
# admin_ip_cidr = "74.47.41.38/32"

# Override only to pin specific image tags (default tracks `latest`):
# odoo_image_tag = "abc1234..."
# frontend_image_tags = {
#   hub       = "abc1234..."
#   goldberry = "abc1234..."
#   ggg       = "abc1234..."
#   nursery   = "abc1234..."
# }
