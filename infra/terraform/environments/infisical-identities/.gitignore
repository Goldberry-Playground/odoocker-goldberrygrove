# Local TF state — never committed; this env uses the remote s3 backend in
# grove-tf-state, but local .terraform/ and any stray state files are still
# excluded to be safe.
terraform.tfstate
terraform.tfstate.backup
terraform.tfstate.*.backup
.terraform/
crash.log
crash.*.log

# Operator-specific tfvars (real values). The .example file IS committed.
terraform.tfvars
*.auto.tfvars

# Backend config holds the bucket + key (non-secret) but is per-operator. The
# .example IS committed.
backend.hcl

# Override the root .gitignore exclusion of .env.* — .env.op IS committed
# (contains op:// references, not secret values, same pattern as state-backend).
!.env.op
