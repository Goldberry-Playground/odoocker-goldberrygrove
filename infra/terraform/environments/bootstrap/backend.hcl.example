# DigitalOcean Spaces — S3-compatible Terraform remote state backend
# Copy to backend.hcl, fill in real values, and git-ignore backend.hcl.
#
# Usage (one-time per machine):
#   cd infra/terraform/environments/bootstrap
#   cp backend.hcl.example backend.hcl
#   export AWS_ACCESS_KEY_ID=<existing grove-tf-state RW access key>
#   export AWS_SECRET_ACCESS_KEY=<existing grove-tf-state RW secret key>
#   terraform init -backend-config=backend.hcl

endpoint = "https://nyc3.digitaloceanspaces.com"
bucket   = "grove-tf-state"
key      = "preview/bootstrap/terraform.tfstate"
region   = "us-east-1" # DO Spaces always uses us-east-1 for the S3 API region field

skip_credentials_validation = true
skip_metadata_api_check     = true
skip_region_validation      = true
skip_requesting_account_id  = true
force_path_style            = true

# Credentials — set via environment variables (NOT here):
#   AWS_ACCESS_KEY_ID     = DO Spaces RW key for grove-tf-state
#   AWS_SECRET_ACCESS_KEY = DO Spaces RW secret for grove-tf-state
