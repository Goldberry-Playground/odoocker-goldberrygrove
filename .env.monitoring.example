###############################################################################
# Grove monitoring stack — env contract for docker-compose.monitoring.yml.
#
# Copy to .env.monitoring and fill in the Discord webhook URLs + a generated
# Keep webhook token. Other values are dev-safe defaults that work locally.
#
# In M2+ (preview droplets / production), these get replaced with real Discord
# server webhooks pointed at the on-call channel and longer Keep tokens.
###############################################################################

# ── Image pins ──────────────────────────────────────────────────────────────
OPENOBSERVE_TAG=v0.17.2
KEEP_TAG=latest

# ── Host-side ports ─────────────────────────────────────────────────────────
OPENOBSERVE_PORT=5080
KEEP_PORT=3034
KEEP_BACKEND_PORT=8080

# ── OpenObserve root user (dev creds; rotate on any non-local deploy) ──────
OPENOBSERVE_ROOT_EMAIL=monitoring@grove.local
OPENOBSERVE_ROOT_PASSWORD=ChangeMe_OnFirstDeploy_2026

# ── Keep secrets ────────────────────────────────────────────────────────────
# WEBHOOK_TOKEN: included as a bearer in the OpenObserve→Keep POST so Keep
# rejects unauthenticated alert ingest. Generate: openssl rand -hex 32
KEEP_WEBHOOK_TOKEN=dev_keep_webhook_token_replace_for_prod

# NEXTAUTH_SECRET: NextAuth.js session secret for the Keep frontend.
# Generate: openssl rand -hex 32
KEEP_NEXTAUTH_SECRET=dev_keep_nextauth_secret_replace_for_prod

# ── Discord webhook URLs (REQUIRED — Keep will not route without these) ────
# Create two webhooks via Discord:
#   Server Settings → Integrations → Webhooks → New Webhook
# Suggested channel structure:
#   #grove-alerts-warning  — HTTP non-2xx >60s, SSL <30 days, etc.
#   #grove-alerts-critical — service down >30s, Postgres TCP failed
# The critical workflow injects @here into the message body for paging.
DISCORD_WEBHOOK_WARNING=https://discord.com/api/webhooks/REPLACE_ME/warning_token
DISCORD_WEBHOOK_CRITICAL=https://discord.com/api/webhooks/REPLACE_ME/critical_token

# ── Synthetic Tier-1 runner (Hurl) ──────────────────────────────────────────
# Dev-safe defaults; the runner reaches Odoo + OpenObserve by service-name DNS
# on the shared gatheratthegrove_internal network. In M2+ SYNTHETIC_ODOO_BASE
# + OPENOBSERVE_OTLP_METRICS_URL become the public/obs-droplet hostnames and
# SYNTHETIC_ENV becomes qa|prod (it tags every metric).
SYNTHETIC_ODOO_BASE=http://odoo:8069
SYNTHETIC_TENANTS=goldberry,ggg,nursery
SYNTHETIC_ENV=local
OPENOBSERVE_OTLP_METRICS_URL=http://openobserve:5080/api/default/v1/metrics

# ── Synthetic checkout-canary (OPT-IN — needs an Odoo API key) ──────────────
# OFF by default. When true, the runner tests the money path every cycle (per
# tenant): create a $0 order for the shared SYNTHETIC-CANARY product via the
# bearer /orders endpoint → verify the access_token gate → delete the draft
# order via XML-RPC. setup-monitoring.py seeds the (unpublished, $0) product.
# SYNTHETIC_ODOO_API_KEY is used for BOTH the HTTP bearer and XML-RPC auth —
# scope it to a least-privilege Odoo user (create order/product + unlink
# sale.order). ODOO_DB must match the running Odoo database.
SYNTHETIC_CANARY_ENABLED=false
ODOO_XMLRPC_URL=http://odoo:8069
ODOO_DB=grove
ODOO_LOGIN=admin
SYNTHETIC_ODOO_API_KEY=replace_me_with_an_odoo_api_key

# ── CostOps DO billing bridge (OPT-IN — needs a DO API token) ───────────────
# OFF by default; cloud-only (no DO account to bill against locally). When true,
# the bridge polls the DigitalOcean API hourly and ships cost as OTLP metrics:
# account MTD/balance actuals + per-resource derived cost (inventory × price
# list). Use a READ-ONLY DO token. COST_MONTHLY_BUDGET drives the cost-budget-*
# alerts (set to your target $/mo; 0 disables the budget alerts).
COST_BRIDGE_ENABLED=false
DO_API_TOKEN=replace_me_with_a_readonly_do_token
COST_ENV=local
COST_MONTHLY_BUDGET=0

# ── Synthetic ghost-content (OPT-IN — needs per-tenant Ghost Content keys) ──
# OFF by default. When true, the runner checks each tenant's Ghost blog has
# published posts (Content API v5), catching a rotated/invalid key or empty
# blog that the ghost-*-admin availability monitors can't see. Provide a URL +
# read-only Content API key per tenant (GHOST_{URL,KEY}_<TENANT>). Missing a
# tenant's pair just skips that tenant.
SYNTHETIC_GHOST_ENABLED=false
GHOST_URL_GOLDBERRY=http://ghost-goldberry:2368
GHOST_KEY_GOLDBERRY=replace_me_with_a_ghost_content_key
GHOST_URL_GGG=http://ghost-ggg:2369
GHOST_KEY_GGG=replace_me_with_a_ghost_content_key
GHOST_URL_NURSERY=http://ghost-nursery:2370
GHOST_KEY_NURSERY=replace_me_with_a_ghost_content_key

# ── OTel Collector (USE / infra metrics) ────────────────────────────────────
# Ships host CPU/RAM/disk + per-container CPU/RAM to OpenObserve — the USE
# metrics the CostOps rightsizing dashboard joins with cost. Always on (no
# secret needed; reuses the OpenObserve root creds). OPENOBSERVE_OTLP_BASE is
# the OTLP endpoint base (the exporter appends /v1/metrics); point it at the
# obs-droplet URL in QA/prod (e.g. https://oo.qa-l3.gatheringatthegrove.com/api/default).
OTELCOL_TAG=0.115.0
OPENOBSERVE_OTLP_BASE=http://openobserve:5080/api/default

# ── Beyla — eBPF RED metrics for Odoo ───────────────────────────────────────
# Grafana Beyla (privileged + pid:host) attaches to the Odoo process by port
# and emits RED metrics per HTTP route, zero Odoo code. Exports OTLP to the
# local otel-collector (no auth needed). Needs a Linux host + compatible kernel;
# no-op (logs only) if it can't attach.
BEYLA_TAG=1.9.4
