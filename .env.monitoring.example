###############################################################################
# Grove monitoring stack — env contract for docker-compose.monitoring.yml.
#
# Copy to .env.monitoring and fill in the Discord webhook URLs + a generated
# Keep webhook token. Other values are dev-safe defaults that work locally.
#
# In M2+ (preview droplets / production), these get replaced with real Discord
# server webhooks pointed at the on-call channel and longer Keep tokens.
###############################################################################

# ── Image pins (never :latest — prod pins via release-manifest/tfvars) ───────
OPENOBSERVE_TAG=v0.17.2
KEEP_TAG=v0.54.1

# ── Host-side ports ─────────────────────────────────────────────────────────
OPENOBSERVE_PORT=5080
KEEP_PORT=3034
KEEP_BACKEND_PORT=8080

# ── scripts/setup-monitoring.py targeting (GOL-278) ──────────────────────────
# Local `make monitoring-setup` leaves these unset (defaults hit localhost).
# To bootstrap a REMOTE obs droplet (e.g. from the agenticos vantage), run the
# script in a python:3.12-slim container ON the grove-obs_obs network and set:
#   OPENOBSERVE_BASE_URL=http://openobserve:5080
#   KEEP_BASE_URL=http://keep-backend:8080
# KEEP_EVENT_URL is the address OpenObserve's alert destination POSTs to reach
# Keep. OO v0.91.1's SSRF guard REJECTS a private-IP destination at create time,
# so this MUST be an SSRF-allowed address (the droplet's PUBLIC IP with
# keep-backend published admin-only + firewalled — hairpin NAT verified; or a
# loopback address with ZO_SSRF_ALLOW_LOOPBACK=true). Leave unset to skip the OO
# destination + alert load (Keep→Discord routing still works via workflows).
# OPENOBSERVE_BASE_URL=
# KEEP_BASE_URL=
# KEEP_EVENT_URL=

# ── OpenObserve root user (dev creds — MUST rotate for any non-local deploy) ──
OPENOBSERVE_ROOT_EMAIL=monitoring@grove.local
OPENOBSERVE_ROOT_PASSWORD=ChangeMe_OnFirstDeploy_2026
# Single-node by default. Prod may set false + add an etcd sidecar for HA.
OPENOBSERVE_LOCAL_MODE=true

# ── Keep secrets + auth ──────────────────────────────────────────────────────
# AUTH_TYPE: NO_AUTH is fine ONLY where the Keep UI/API is firewalled to admins
# (local dev, or an obs droplet with an admin-only firewall). For any publicly
# reachable prod Keep, set this to a real auth mode (e.g. DB) + provision users.
KEEP_AUTH_TYPE=NO_AUTH

# WEBHOOK_TOKEN: included as a bearer in the OpenObserve→Keep POST so Keep
# rejects unauthenticated alert ingest. Generate: openssl rand -hex 32
KEEP_WEBHOOK_TOKEN=dev_keep_webhook_token_replace_for_prod

# NEXTAUTH_SECRET: NextAuth.js session secret for the Keep frontend.
# Generate: openssl rand -hex 32
KEEP_NEXTAUTH_SECRET=dev_keep_nextauth_secret_replace_for_prod

# ── Discord webhook URLs (REQUIRED — Keep will not route without these) ────
# Create two webhooks via Discord:
#   Server Settings → Integrations → Webhooks → New Webhook
# Suggested channel structure:
#   #grove-alerts-warning  — HTTP non-2xx >60s, SSL <30 days, etc.
#   #grove-alerts-critical — service down >30s, Postgres TCP failed
# The critical workflow injects @here into the message body for paging.
DISCORD_WEBHOOK_WARNING=https://discord.com/api/webhooks/REPLACE_ME/warning_token
DISCORD_WEBHOOK_CRITICAL=https://discord.com/api/webhooks/REPLACE_ME/critical_token

# ── Synthetic Tier-1 runner (Hurl) ──────────────────────────────────────────
# Dev-safe defaults; the runner reaches Odoo + OpenObserve by service-name DNS
# on the shared gatheratthegrove_internal network. In M2+ SYNTHETIC_ODOO_BASE
# + OPENOBSERVE_OTLP_METRICS_URL become the public/obs-droplet hostnames and
# SYNTHETIC_ENV becomes qa|prod (it tags every metric).
SYNTHETIC_ODOO_BASE=http://odoo:8069
SYNTHETIC_TENANTS=goldberry,ggg,nursery
SYNTHETIC_ENV=local
OPENOBSERVE_OTLP_METRICS_URL=http://openobserve:5080/api/default/v1/metrics
#
# ── CROSS-PLANE (GOL-280): ship to the separate grove-obs droplet ────────────
# The obs plane (OpenObserve + Keep) is a SEPARATE droplet (GOL-270). To make
# the alert streams exist, every telemetry source on the app/Odoo droplet must
# ship OTLP to grove-obs:5080 instead of a co-located OpenObserve. In the
# app-plane .env.monitoring set BOTH OTLP bases to the obs droplet (use the
# `terraform output` IP/hostname — GOL-270 opened the :5080 ingest firewall to
# the app droplet's IP). Example:
#   OPENOBSERVE_OTLP_METRICS_URL=http://<grove-obs>:5080/api/default/v1/metrics
#   OPENOBSERVE_OTLP_BASE=http://<grove-obs>:5080/api/default
# and set the OpenObserve root creds below to the grove-obs root creds (op://
# Goldberry Grove - Admin/Grove Infra/obs_openobserve_root_*). SYNTHETIC_ENV=qa|prod.
#
# ── Availability + SSL probes (synthetic_uptime / synthetic_ssl_days) ────────
# GOL-280: the runner probes the HTTP/TCP/SSL targets in openobserve/monitors.json
# and emits the synthetic_uptime + synthetic_ssl_days streams the frontend/odoo/
# ghost/postgres/ssl alerts fire on (OpenObserve has no /synthetic endpoint).
# ON by default. Disable in envs where the availability targets aren't reachable
# (e.g. a laptop with no storefront containers) so it doesn't emit false-down.
# Per-target URL/host/port overrides for prod topology (host.docker.internal ->
# public hostname) via SYNTHETIC_MONITOR_URL_<NAME> / SYNTHETIC_MONITOR_HOST_<NAME>
# / SYNTHETIC_MONITOR_PORT_<NAME> (NAME = monitor name upper-cased, '-' -> '_';
# e.g. SYNTHETIC_MONITOR_URL_HUB_ROOT). The app-plane compose forwards these into
# the synthetic-runner via explicit ${...} passthrough (GOL-334), so set them here
# in the deploy's --env-file. An unset var falls back to the monitors.json default.
SYNTHETIC_UPTIME_ENABLED=true
#
# ── GOL-334: live qa (qa.gatheringatthegrove.com) target overrides ───────────
# Frontends — DO App Platform apps, public CF hostnames (NOT behind the apex CF
# WAF; the qa zone is DO-delegated). root targets assert a keyword.
# SYNTHETIC_MONITOR_URL_HUB_ROOT=https://hub.qa.gatheringatthegrove.com/
# SYNTHETIC_MONITOR_URL_HUB_JOURNAL=https://hub.qa.gatheringatthegrove.com/journal
# SYNTHETIC_MONITOR_URL_GOLDBERRY_ROOT=https://goldberry.qa.gatheringatthegrove.com/
# SYNTHETIC_MONITOR_URL_GOLDBERRY_SHOP=https://goldberry.qa.gatheringatthegrove.com/shop
# SYNTHETIC_MONITOR_URL_GOLDBERRY_BLOG=https://goldberry.qa.gatheringatthegrove.com/blog
# SYNTHETIC_MONITOR_URL_GGG_ROOT=https://ggg.qa.gatheringatthegrove.com/
# SYNTHETIC_MONITOR_URL_GGG_SHOP=https://ggg.qa.gatheringatthegrove.com/shop
# SYNTHETIC_MONITOR_URL_GGG_BLOG=https://ggg.qa.gatheringatthegrove.com/blog
# SYNTHETIC_MONITOR_URL_NURSERY_ROOT=https://nursery.qa.gatheringatthegrove.com/
# SYNTHETIC_MONITOR_URL_NURSERY_SHOP=https://nursery.qa.gatheringatthegrove.com/shop
# SYNTHETIC_MONITOR_URL_NURSERY_BLOG=https://nursery.qa.gatheringatthegrove.com/blog
# Ghost admin — shared blogs droplet (grove-prod-blogs) via CF-proxied apex
# blog.* hosts (no separate qa Ghost). Needs the GroveSyntheticMonitor UA
# (probes.py) to clear CF Bot Fight Mode; /ghost/api/admin/site/ -> 200/401 up.
# SYNTHETIC_MONITOR_URL_GHOST_GOLDBERRY_ADMIN=https://blog.goldberrygrove.farm/ghost/api/admin/site/
# SYNTHETIC_MONITOR_URL_GHOST_GGG_ADMIN=https://blog.woodworkingeorge.com/ghost/api/admin/site/
# SYNTHETIC_MONITOR_URL_GHOST_NURSERY_ADMIN=https://blog.atthegrovenursery.com/ghost/api/admin/site/
# Postgres TCP — DO Managed PG private host + port 25060 (not local-dev 5432).
# SYNTHETIC_MONITOR_HOST_POSTGRES_TCP=private-grove-qa-l3-pg-do-user-1201760-0.e.db.ondigitalocean.com
# SYNTHETIC_MONITOR_PORT_POSTGRES_TCP=25060
# odoo-health needs no override (odoo:8069 resolves on the grove network);
# ssl-* need none (they probe the public apex domains directly).

# ── Synthetic checkout-canary (OPT-IN — needs an Odoo API key) ──────────────
# OFF by default. When true, the runner tests the money path every cycle (per
# tenant): create a $0 order for the shared SYNTHETIC-CANARY product via the
# bearer /orders endpoint → verify the access_token gate → delete the draft
# order via XML-RPC. setup-monitoring.py seeds the (unpublished, $0) product.
# SYNTHETIC_ODOO_API_KEY is used for BOTH the HTTP bearer and XML-RPC auth —
# scope it to a least-privilege Odoo user (create order/product + unlink
# sale.order). ODOO_DB must match the running Odoo database.
SYNTHETIC_CANARY_ENABLED=false
ODOO_XMLRPC_URL=http://odoo:8069
ODOO_DB=grove
ODOO_LOGIN=admin
SYNTHETIC_ODOO_API_KEY=replace_me_with_an_odoo_api_key

# ── CostOps DO billing bridge (OPT-IN — needs a DO API token) ───────────────
# OFF by default; cloud-only (no DO account to bill against locally). When true,
# the bridge polls the DigitalOcean API hourly and ships cost as OTLP metrics:
# account MTD/balance actuals + per-resource derived cost (inventory × price
# list). Use a READ-ONLY DO token. COST_MONTHLY_BUDGET drives the cost-budget-*
# alerts (set to your target $/mo; 0 disables the budget alerts).
COST_BRIDGE_ENABLED=false
DO_API_TOKEN=replace_me_with_a_readonly_do_token
COST_ENV=local
COST_MONTHLY_BUDGET=0

# ── DO App Platform metrics bridge (OPT-IN — reuses DO_API_TOKEN above) ──────
# OFF by default; cloud-only (no App Platform apps to poll locally). When true,
# polls the DO Monitoring API every 2 min for each app's CPU%/memory%/restart
# count and ships OTLP gauges — the frontend USE metrics the OTel Collector's
# docker_stats can't reach (App Platform has no host/socket). Managed Postgres is
# NOT covered here (DBaaS metrics API is MySQL-only) — its USE comes from the
# postgresql OTel receiver. DO_METRICS_LOOKBACK_SECONDS is the query window; the
# latest in-window point becomes the gauge (600s tolerates DO's ~2 min cadence).
DO_METRICS_ENABLED=false
DO_METRICS_LOOKBACK_SECONDS=600

# ── Synthetic ghost-content (OPT-IN — needs per-tenant Ghost Content keys) ──
# OFF by default. When true, the runner checks each tenant's Ghost blog has
# published posts (Content API v5), catching a rotated/invalid key or empty
# blog that the ghost-*-admin availability monitors can't see. Provide a URL +
# read-only Content API key per tenant (GHOST_{URL,KEY}_<TENANT>). Missing a
# tenant's pair just skips that tenant.
SYNTHETIC_GHOST_ENABLED=false
GHOST_URL_GOLDBERRY=http://ghost-goldberry:2368
GHOST_KEY_GOLDBERRY=replace_me_with_a_ghost_content_key
GHOST_URL_GGG=http://ghost-ggg:2369
GHOST_KEY_GGG=replace_me_with_a_ghost_content_key
GHOST_URL_NURSERY=http://ghost-nursery:2370
GHOST_KEY_NURSERY=replace_me_with_a_ghost_content_key

# ── OTel Collector (USE / infra metrics) ────────────────────────────────────
# Ships host CPU/RAM/disk + per-container CPU/RAM to OpenObserve — the USE
# metrics the CostOps rightsizing dashboard joins with cost. Always on (no
# secret needed; reuses the OpenObserve root creds). OPENOBSERVE_OTLP_BASE is
# the OTLP endpoint base (the exporter appends /v1/metrics); point it at the
# obs-droplet URL in QA/prod (e.g. https://oo.qa-l3.gatheringatthegrove.com/api/default).
OTELCOL_TAG=0.115.0
OPENOBSERVE_OTLP_BASE=http://openobserve:5080/api/default

# ── Beyla — eBPF RED metrics for Odoo ───────────────────────────────────────
# Grafana Beyla (privileged + pid:host) attaches to the Odoo process by port
# and emits RED metrics per HTTP route, zero Odoo code. Exports OTLP to the
# local otel-collector (no auth needed). Needs a Linux host + compatible kernel;
# no-op (logs only) if it can't attach.
BEYLA_TAG=1.9.4

# ── OTel Collector postgresql receiver (OPT-IN — needs a pg_monitor user) ────
# OFF by default (the receiver is defined but NOT in the pipeline — see
# otel/README.md to enable). When you add `postgresql` to the metrics pipeline,
# set these to a READ-ONLY monitoring user (GRANT pg_monitor). Unlocks the
# postgres-connections alerts. Under ADR-007 Postgres is Managed → point
# POSTGRES_ENDPOINT at the managed host:5432.
POSTGRES_ENDPOINT=postgres:5432
POSTGRES_MONITOR_USER=otel_monitor
POSTGRES_MONITOR_PASSWORD=replace_me_with_a_readonly_pg_password
