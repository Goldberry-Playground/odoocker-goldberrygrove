###############################################################################
# Grove self-hosted Plausible — env contract for docker-compose.plausible.yml.
#
# Copy to .env.plausible and fill in the GENERATED secrets + your domain.
# Cloud-only in practice (the frontends must reach it over a public URL); a
# local instance is fine for testing at http://localhost:8000.
###############################################################################

# ── Image pin ────────────────────────────────────────────────────────────────
PLAUSIBLE_TAG=v3.2.1

# ── Public URL + host port ─────────────────────────────────────────────────
# BASE_URL is the public URL Caddy proxies to this instance. It MUST match the
# frontends' NEXT_PUBLIC_PLAUSIBLE_HOST. Local testing: http://localhost:8000
PLAUSIBLE_BASE_URL=https://plausible.gatheringatthegrove.com
PLAUSIBLE_PORT=8000

# ── Secrets — GENERATE these; do NOT ship the placeholders ─────────────────
#   SECRET_KEY_BASE: openssl rand -base64 48
#   TOTP_VAULT_KEY:  openssl rand -base64 32   (must decode to exactly 32 bytes)
PLAUSIBLE_SECRET_KEY_BASE=replace_me_openssl_rand_base64_48
PLAUSIBLE_TOTP_VAULT_KEY=replace_me_openssl_rand_base64_32

# Password for Plausible's OWN metadata Postgres (not odoocker's Odoo PG).
PLAUSIBLE_POSTGRES_PASSWORD=replace_me_with_a_strong_password

# ── Registration ────────────────────────────────────────────────────────────
# invite_only (default) | true (fully disabled) | false.
# FIRST boot: set to `false`, create the admin at BASE_URL/register, then change
# back to `invite_only` (or `true`) and restart so the instance isn't open.
PLAUSIBLE_DISABLE_REGISTRATION=invite_only
