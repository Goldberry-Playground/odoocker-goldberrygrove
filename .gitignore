# Real env files — all variants. Allow committed example/template files.
.env
.env.*
!.env.example
!.env.*.example

# Ignores the pgadmin private key
pgadmin/private_key

# Ignores the docker compose local or production environment.
docker-compose.override.yml

# Ignores any __pycache__ folder.
__pycache__

# MCP server config (contains env-specific paths)
.mcp.json

# macOS metadata
.DS_Store

# Docker bind-mount artifacts. The local-dev overlay binds
# nginx/snippets-dev/cors-allowlist-dev.conf onto
# /etc/nginx/snippets/cors-allowlist-dev.conf — when the parent dir is
# itself a bind from ./nginx/snippets/, the runtime touches an empty
# placeholder file inside ./nginx/snippets/ to create the mountpoint.
# That placeholder should never be committed (it would also defeat the
# whole dev/prod allowlist split because the empty file is then present
# in prod containers).
nginx/snippets/cors-allowlist-dev.conf
