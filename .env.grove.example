###############################################################################
# Grove Ecosystem — Environment Variables
# Copy to .env.grove and fill in real values.
###############################################################################

# ── Ghost CMS URLs ──────────────────────────────────────────────────────────
GHOST_GOLDBERRY_URL=https://blog.goldberrygrove.farm
GHOST_GGG_URL=https://blog.woodworkingeorge.com
GHOST_NURSERY_URL=https://blog.atthegrovenursery.com

# Ghost internal ports (match docker-compose.override.grove.yml)
GHOST_GOLDBERRY_PORT=2368
GHOST_GGG_PORT=2369
GHOST_NURSERY_PORT=2370

# ── Odoo Multi-Company / Multi-Website ──────────────────────────────────────
# Database name for the grove ecosystem
ODOO_DB_NAME=grove_production

# Company IDs (populated after initial Odoo setup)
ODOO_COMPANY_GOLDBERRY_ID=
ODOO_COMPANY_GGG_ID=
ODOO_COMPANY_NURSERY_ID=

# Website IDs (populated after initial Odoo setup)
ODOO_WEBSITE_GOLDBERRY_ID=
ODOO_WEBSITE_GGG_ID=
ODOO_WEBSITE_NURSERY_ID=

# ── Sandbox / Staging ───────────────────────────────────────────────────────
# Set to "staging" for sandbox, "production" for prod
APP_ENV=production

# Sandbox-specific overrides (used by docker-compose.override.sandbox.yml)
SANDBOX_DB_NAME=grove_sandbox
SANDBOX_DOMAIN=erp-sandbox.goldberrygrove.farm
SANDBOX_GHOST_GOLDBERRY_URL=https://blog-sandbox.goldberrygrove.farm
SANDBOX_GHOST_GGG_URL=https://blog-sandbox.woodworkingeorge.com
SANDBOX_GHOST_NURSERY_URL=https://blog-sandbox.atthegrovenursery.com

# ── Nginx / TLS ─────────────────────────────────────────────────────────────
# Comma-separated list of all virtual hosts for cert generation
GROVE_VIRTUAL_HOSTS=erp.goldberrygrove.farm,blog.goldberrygrove.farm,blog.woodworkingeorge.com,blog.atthegrovenursery.com

# ── Feature Flags ───────────────────────────────────────────────────────────
GROVE_HEADLESS_API_ENABLED=true
GROVE_GHOST_ENABLED=true

# ── Headless frontends (Next.js storefronts + hub) ──────────────────────────
# Profile-gated via FRONTENDS_PROFILES in .env. Backend URLs use Docker
# service-name DNS resolved on the `internal` network — no
# host.docker.internal needed when backend + frontends share this compose
# project. See docker-compose.override.grove.yml for the service definitions.

# Storefronts (goldberry, ggg, nursery) — shared Odoo BFF, per-tenant Ghost
ODOO_URL=http://odoo:8069
ODOO_API_KEY=
GHOST_URL_GOLDBERRY=http://ghost-goldberry:2368
GHOST_URL_GGG=http://ghost-ggg:2369
GHOST_URL_NURSERY=http://ghost-nursery:2370
GHOST_CONTENT_KEY_GOLDBERRY=
GHOST_CONTENT_KEY_GGG=
GHOST_CONTENT_KEY_NURSERY=

# Hub (gatheringatthegrove.com) — aggregates across all 3 tenants
GROVE_ODOO_URL=http://odoo:8069
HUB_GHOST_URL=http://ghost-goldberry:2368
HUB_GHOST_CONTENT_API_KEY=

# Shared secret for /api/revalidate webhook on hub.
# Generate: `openssl rand -hex 32`
GROVE_REVALIDATE_SECRET=

# Host-side ports for local dev (used by override.local.yml).
# Container-internal ports come from each Dockerfile's `ENV PORT=...`
# (storefronts: 3001, hub: 3000). Conflict-free defaults.
HUB_PORT=3000
GOLDBERRY_PORT=3001
GGG_PORT=3002
NURSERY_PORT=3003

# ── Frontend nginx-proxy routing (VIRTUAL_HOST / TLS) ───────────────────────
# Each frontend in docker-compose.override.grove.yml carries VIRTUAL_HOST,
# VIRTUAL_PORT (fixed: hub 3000, storefronts 3001) and LETSENCRYPT_HOST.
# VIRTUAL_HOST defaults to EMPTY in the grove overlay, so nginx-proxy ignores
# the frontends unless a host is set here — no clash with the Odoo/Ghost vhosts.
#
#   - Local: override.local.yml defaults these to `<name>.localhost`, so
#     `--profile frontends --profile proxy up` serves all 4 behind nginx-proxy
#     on :80 (http://hub.localhost, http://goldberry.localhost, etc.). Leave
#     the vars below unset locally to use those defaults.
#   - Preview/prod: set the real hostnames (assigned by the per-PR preview
#     droplet / apex->subdomain work, GOL-6 / GOL-7). Setting *_LETSENCRYPT_HOST
#     (usually == *_VIRTUAL_HOST) makes acme-companion issue a TLS cert when the
#     `acme` profile is up. Comma-separate multiple hostnames if needed.
# HUB_VIRTUAL_HOST=gatheringatthegrove.com
# HUB_LETSENCRYPT_HOST=gatheringatthegrove.com
# GOLDBERRY_VIRTUAL_HOST=goldberrygrove.farm
# GOLDBERRY_LETSENCRYPT_HOST=goldberrygrove.farm
# GGG_VIRTUAL_HOST=woodworkingeorge.com
# GGG_LETSENCRYPT_HOST=woodworkingeorge.com
# NURSERY_VIRTUAL_HOST=atthegrovenursery.com
# NURSERY_LETSENCRYPT_HOST=atthegrovenursery.com
