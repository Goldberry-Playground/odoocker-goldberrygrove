# Operator template — copy to .env.infisical-seed.op (git-ignored) and use:
#
#   op run --env-file=.env.infisical-seed.op -- ./scripts/infisical-seed.sh
#
# The op:// references resolve at runtime from the GoldberryGrove Infra item
# in the "Goldberry Grove - Admin" 1Password vault. Per
# [[feedback_1password_secrets]] no values touch shell scrollback or history.
#
# Decision context: [[project_infisical_decision_cloud]] +
# [[reference_infisical_cloud_org]]

# ── Infisical Cloud auth ────────────────────────────────────────────────────
# Generate via Infisical UI → Project Settings → Access Control → Machine
# Identities → Create Identity → Universal Auth. Scope: secrets:write,
# secrets:read on the project. Save the resulting token to 1Password as
# `infisical_service_token_odoocker`.
INFISICAL_TOKEN=op://Goldberry Grove - Admin/GoldberryGrove Infra/infisical_service_token_odoocker

# Project slug + env to seed (literals; not 1P refs)
INFISICAL_PROJECT_ID=grove-odoocker
INFISICAL_ENV_SLUG=prod

# ── Secret values to seed ────────────────────────────────────────────────────
# These should match what odoocker GH workflows currently consume. The four
# below are what odoocker's sandbox-deploy, sandbox-reaper, terraform-drift,
# and release workflows actually reference today.

DIGITALOCEAN_TOKEN=op://Goldberry Grove - Admin/GoldberryGrove Infra/do_token
DISCORD_OPS_WEBHOOK_URL=op://Goldberry Grove - Admin/GoldberryGrove Infra/discord_webhook_url

# NOTE: The workflow Spaces keys (grove-tf-state-rw) live only in Terraform
# state — they're TF-created in state-backend/ env and pushed to GH Secrets,
# never written back to 1Password. Until that's fixed, fetch them at seed
# time:
#
#   cd infra/terraform/environments/state-backend
#   export SPACES_ACCESS_KEY_ID=$(terraform output -raw spaces_access_key_id)
#   export SPACES_SECRET_ACCESS_KEY=$(terraform output -raw spaces_secret_access_key)
#   cd ../../../..
#   op run --env-file=.env.infisical-seed.op -- ./scripts/infisical-seed.sh
#
# Follow-up: add `1password_item` resources to state-backend/main.tf that
# write these keys to GoldberryGrove Infra so this manual step goes away.
SPACES_ACCESS_KEY_ID=
SPACES_SECRET_ACCESS_KEY=
