# Operator template — copy to .env.infisical-seed.op (git-ignored) and use:
#
#   op run --env-file=.env.infisical-seed.op -- ./scripts/infisical-seed.sh
#
# The op:// references resolve at runtime from the GoldberryGrove Infra item
# in the "Goldberry Grove - Admin" 1Password vault. Per
# [[feedback_1password_secrets]] no values touch shell scrollback or history.
#
# Decision context: [[project_infisical_decision_cloud]] +
# [[reference_infisical_cloud_org]]

# ── Infisical Cloud auth (Universal Auth client credentials) ────────────────
# Generate via Infisical UI:
#   1. Org → Access Control → Identities → Create Identity (name: seed-script-odoocker)
#   2. Add Auth Method → Universal Auth → save → copy Client ID
#   3. Create Client Secret on the same page → copy Secret (shown once)
#   4. Project (grove-odoocker) → Access Control → Machine Identities → Add Identity
#      → select seed-script-odoocker → role: Developer (read+write)
#   5. Save BOTH values to 1Password GoldberryGrove Infra item:
#        infisical_client_id_odoocker      — the Client ID
#        infisical_client_secret_odoocker  — the Client Secret
#
# The Infisical CLI auto-exchanges these for a fresh access token on each
# invocation, so the script keeps working weeks/months apart without a
# token-expiry surprise.
INFISICAL_UNIVERSAL_AUTH_CLIENT_ID=op://Goldberry Grove - Admin/GoldberryGrove Infra/infisical_client_id_odoocker
INFISICAL_UNIVERSAL_AUTH_CLIENT_SECRET=op://Goldberry Grove - Admin/GoldberryGrove Infra/infisical_client_secret_odoocker

# Project UUID + env slug to seed (literals; not 1P refs).
#
# IMPORTANT: INFISICAL_PROJECT_ID is the project's UUID, NOT the human-readable
# slug. The CLI flag is misleadingly named --projectId; the API requires the
# UUID. Grab it from your browser URL when viewing the project:
#   https://app.infisical.com/organization/<org-uuid>/secret-manager/<THIS-IS-IT>/overview
#
# The env slug IS the slug shown in the Environments tab — default "prod" works
# for the dev/staging/prod environments Infisical auto-creates on new projects.
INFISICAL_PROJECT_ID=REPLACE_WITH_PROJECT_UUID
INFISICAL_ENV_SLUG=prod

# ── Secret values to seed ────────────────────────────────────────────────────
# These should match what odoocker GH workflows currently consume. The four
# below are what odoocker's sandbox-deploy, sandbox-reaper, terraform-drift,
# and release workflows actually reference today.

DIGITALOCEAN_TOKEN=op://Goldberry Grove - Admin/GoldberryGrove Infra/do_token
DISCORD_OPS_WEBHOOK_URL=op://Goldberry Grove - Admin/GoldberryGrove Infra/discord_webhook_url

# Spaces credentials: using the bootstrap keys here. They have broader scope
# than the bucket-scoped grove-tf-state-rw workflow key (all-buckets vs one
# bucket) but they ARE in 1Password (the workflow key's secret_key was only
# revealed once at TF apply time, and that state file is no longer recoverable).
#
# Trade-off accepted 2026-06-23: broader-scope key in CI in exchange for
# functional simplicity (no rotation dance). Tighten to a bucket-scoped key in
# a future cleanup if/when state-backend TF state is rebuilt — that PR would
# also rotate to a fresh grove-tf-state-rw-v2 and update these references.
SPACES_ACCESS_KEY_ID=op://Goldberry Grove - Admin/GoldberryGrove Infra/spaces_bootstrap_access_key_id
SPACES_SECRET_ACCESS_KEY=op://Goldberry Grove - Admin/GoldberryGrove Infra/spaces_bootstrap_secret_key
